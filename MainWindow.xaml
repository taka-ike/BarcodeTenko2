<Window x:Class="Tenko.Native.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Tenko.Native"
        mc:Ignorable="d"
        Title="Tenko Native" Height="600" Width="800"
        FontFamily="Yu Gothic UI, Meiryo"
        PreviewKeyDown="Window_PreviewKeyDown">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <local:NotificationTypeToBrushConverter x:Key="TypeToBrush" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#F3F3F3" Padding="10" BorderBrush="#DDD" BorderThickness="0,0,0,1">
            <DockPanel>
                <Button Content="設定" DockPanel.Dock="Right" Click="SettingsButton_Click" Padding="10,5"/>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="現在の場所: " FontWeight="Bold"/>
                    <TextBlock Text="{Binding CurrentLocation}" Margin="5,0,0,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="ManualInputBox" Text="{Binding ManualInput, UpdateSourceTrigger=PropertyChanged}" 
                         FontSize="24" Margin="0,0,10,0" 
                         KeyDown="ManualInputBox_KeyDown"/>
                <Button Grid.Column="1" Content="送信" Command="{Binding SubmitCommand}" Padding="20,5" FontSize="18"/>
            </Grid>

            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,20,0,0">
                <TextBlock Text="スキャン件数: " VerticalAlignment="Center"/>
                <TextBlock Text="{Binding History.Count}" FontWeight="Bold" VerticalAlignment="Center" Margin="5,0,20,0"/>
                <Button Content="CSV出力" Command="{Binding ExportCsvCommand}" Margin="0,0,10,0" Padding="10,5"/>
                <Button Content="BIN出力" Command="{Binding ExportBinCommand}" Margin="0,0,10,0" Padding="10,5"/>
                <Button Content="全履歴削除" Command="{Binding DeleteAllCommand}" Background="#FFE0E0" Padding="10,5"/>
            </StackPanel>
        </Grid>

        <DataGrid Grid.Row="2" ItemsSource="{Binding History}" AutoGenerateColumns="False" 
                  IsReadOnly="True" Margin="10" GridLinesVisibility="Horizontal" HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="時刻" Binding="{Binding FormattedTimestamp}" Width="150"/>
                <DataGridTextColumn Header="バーコード" Binding="{Binding Barcode}" Width="*"/>
                <DataGridTextColumn Header="ID下5桁" Binding="{Binding Last5, StringFormat='\{0:D5\}'}" Width="100"/>
                <DataGridTextColumn Header="場所" Binding="{Binding Location}" Width="150"/>
                <DataGridTemplateColumn Header="操作" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="削除" Command="{Binding DataContext.DeleteRecordCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                    CommandParameter="{Binding}" Margin="2"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.RowSpan="3" VerticalAlignment="Top" Margin="20" Padding="15" CornerRadius="5"
                Background="{Binding NotificationType, Converter={StaticResource TypeToBrush}}"
                Visibility="{Binding IsNotificationVisible, Converter={StaticResource BoolToVis}}"
                Panel.ZIndex="100" HorizontalAlignment="Center">
            <TextBlock Text="{Binding NotificationMessage}" Foreground="White" FontWeight="Bold"/>
        </Border>

        <Border Grid.RowSpan="3" Background="#80000000" Visibility="{Binding ShowBinWarning, Converter={StaticResource BoolToVis}}" Panel.ZIndex="200">
            <Border Background="White" Width="400" Height="250" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="20" CornerRadius="10">
                <StackPanel>
                    <TextBlock Text="既存データ警告" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
                    <TextBlock Text="この場所のデータファイル(ids_*.bin)が既に存在します。名前を変更して保存するか、このまま追記しますか？" TextWrapping="Wrap" Margin="0,0,0,20"/>
                    <TextBox x:Name="RenameTextBox" Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="名前変更" Click="RenameButton_Click" Padding="15,5" Margin="0,0,10,0"/>
                        <Button Content="そのまま続行" Click="DismissWarning_Click" Padding="15,5"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <Border x:Name="SettingsModal" Grid.RowSpan="3" Background="#80000000" Visibility="Collapsed" Panel.ZIndex="300">
            <Border Background="White" Width="300" Height="200" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="20" CornerRadius="10">
                <StackPanel>
                    <TextBlock Text="設定" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
                    <TextBlock Text="場所を選択してください:" Margin="0,0,0,5"/>
                    <ComboBox ItemsSource="{Binding Locations}" SelectedItem="{Binding CurrentLocation, Mode=TwoWay}" Margin="0,0,0,20"/>
                    <Button Content="閉じる" Click="CloseSettings_Click" HorizontalAlignment="Right" Padding="15,5"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>
